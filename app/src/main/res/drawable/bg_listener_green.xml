<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="oval">
            <solid android:color="#25C486" /> <stroke
            android:width="4dp"
            android:color="#02081B" /> </shape>
    </item>

    <item
        android:bottom="20dp"
        android:left="20dp"
        android:right="20dp"
        android:top="20dp">
        <bitmap
            android:gravity="center"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:tint="#02081B" />
    </item>

</layer-list>