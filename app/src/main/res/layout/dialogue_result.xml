<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E602081B"
    android:backgroundTint="#E602081B"
    android:gravity="center"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mainCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="#121A2D"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:cardUseCompatPadding="true"
        app:strokeColor="#FFD700"
        app:strokeWidth="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="30dp">

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <TextView
                android:id="@+id/txtResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXCELLENT!"
                android:textColor="#FFD700"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtResultMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:text="You are becoming a Master Hafiz"
                android:textColor="#B0BEC5"
                android:textSize="14sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:rowCount="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SCORE"
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/valScore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="150"
                        android:textColor="#FFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="HIGHEST SCORE"
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/valBest"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2400"
                        android:textColor="#FFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="WORDS"
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/valWords"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="#FFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DAILY MISSION"
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/valDaily"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="5/10"
                        android:textColor="#FFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </GridLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="60dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlayAgain"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="PLAY AGAIN"
                android:textColor="#000"
                android:textSize="16sp"
                app:backgroundTint="#FFD700"
                app:cornerRadius="15dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoHome"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="HOME"
                android:textColor="#FFF"
                app:cornerRadius="15dp"
                app:strokeColor="#80FFFFFF" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</RelativeLayout>