<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_guess_activity"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_dark"
    android:orientation="vertical"
    android:weightSum="15"
    tools:context=".GuessGameActivity" >

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.75"
        android:background="#00F5FFFF"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="8">

        <ImageButton
            android:id="@+id/pause_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="0dp"
            android:layout_weight="1"
            android:background="#00F5FFFF"
            android:scaleType="fitCenter"
            app:srcCompat="@android:drawable/ic_media_pause"
            app:tint="#BFBFBF" />

        <ImageButton
            android:id="@+id/daily_mission_dialog_btn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="0dp"
            android:layout_weight="1"
            android:background="#00F5FFFF"
            android:scaleType="fitCenter"
            app:srcCompat="@android:drawable/ic_menu_today"
            app:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/settings_dialog_btn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="0dp"
            android:layout_weight="1"
            android:background="#00F5FFFF"
            android:scaleType="fitCenter"
            app:srcCompat="@android:drawable/ic_menu_manage"
            app:tint="#FDFEFF" />

        <androidx.cardview.widget.CardView
            android:id="@+id/stages_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_marginStart="0dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:layout_weight="1.5"
            app:cardBackgroundColor="#FFC107"
            app:cardCornerRadius="2dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintBottom_toTopOf="@+id/linearLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/constraintLayout">

            <TextView
                android:id="@+id/stages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Stage 00"
                android:textColor="@color/navy_dark"
                android:textSize="14sp"
                android:textStyle="normal|bold" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="4dp"
            android:layout_weight="3.5"
            android:orientation="horizontal"
            android:weightSum="5">

            <ImageButton
                android:id="@+id/live1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#00F5FFFF"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/heart" />

            <ImageButton
                android:id="@+id/live2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#00F5FFFF"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/heart" />

            <ImageButton
                android:id="@+id/live3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#00F5FFFF"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/heart" />

            <ImageButton
                android:id="@+id/live4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#00F5FFFF"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/heart" />

            <ImageButton
                android:id="@+id/live5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#00F5FFFF"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/heart" />

        </LinearLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar2"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_weight="0.75"
        android:indeterminate="false"
        android:max="10"
        android:mirrorForRtl="false"
        android:progress="9"
        android:progressBackgroundTint="@color/ic_launcher_background"
        android:progressBackgroundTintMode="src_over"
        android:progressTint="@color/gray_400"
        android:progressTintMode="src_over" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_weight="0.75"
        android:orientation="horizontal"
        android:weightSum="2">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:cardBackgroundColor="#FFC107"
            app:cardCornerRadius="2dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true">

            <TextView
                android:id="@+id/totalWordCount"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:gravity="center|start"
                android:text="Words: 0"
                android:textColor="#02081B"
                android:textSize="16sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:cardBackgroundColor="#FFC107"
            app:cardCornerRadius="2dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true">

            <TextView
                android:id="@+id/scoreCount"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:gravity="center|start"
                android:text="Score: 0"
                android:textColor="#02081B"
                android:textSize="16sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_weight="0.75"
        android:orientation="horizontal"
        android:weightSum="3">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:cardBackgroundColor="#FFC107"
            app:cardCornerRadius="2dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true">

            <TextView
                android:id="@+id/cardsCount"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:gravity="center|start"
                android:text="0/0 Cards"
                android:textColor="#02081B"
                android:textSize="16sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            app:cardBackgroundColor="#FFC107"
            app:cardCornerRadius="2dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true">

            <TextView
                android:id="@+id/hScore"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:gravity="center|start"
                android:text="Highest score: 100000"
                android:textColor="#02081B"
                android:textSize="16sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/guess_quize_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="11">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ProgressBar
                android:id="@+id/progressBar4"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="#00B0FF"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#4FACFE"
        app:cardCornerRadius="2dp"
        app:cardUseCompatPadding="false">

        <Button
            android:id="@+id/next"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:backgroundTint="#4FACFE"
            android:gravity="center"
            android:layoutDirection="inherit"
            android:text="NEXT"
            android:textColor="#02081B"
            android:textSize="20sp"
            android:textStyle="bold"
            app:cornerRadius="0dp" />
    </androidx.cardview.widget.CardView>
</LinearLayout>